# trend-viewer runs keyless by design — no API keys required.
# Optional overrides:
TREND_VIEWER_PORT=8779
TREND_VIEWER_CACHE_TTL=3600

# Optional local Responses proxy; failures fall back to heuristics.
# Set to 0 to skip the proxy call.
TREND_ANALYSIS_ENABLED=1
TREND_ANALYSIS_BASE_URL=http://127.0.0.1:10100/v1
TREND_ANALYSIS_MODEL=cursor/gpt-5.6-luna
